["create","E2-001",1773604016,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"Implement multi-branch mode","type":"story","definition_of_done":"Issues and op log stored on separate issues/ branch. Worker ops read/write to that branch without affecting working branch. All existing single-branch tests pass. Config flag or auto-detection switches modes.","priority":"high"}]
["create","E2-002",1773604016,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"Branch isolation for worker operations","type":"story","definition_of_done":"Worker commands (claim, note, heartbeat, transition) read/write exclusively to issues branch in multi-branch mode. No cross-contamination of working branch history.","priority":"high"}]
["create","E2-003",1773604016,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"Cross-branch merge detection and auto-transition","type":"story","definition_of_done":"When working branch merges into main, Trellis detects merge and auto-transitions associated in-progress issues to merged state. Via post-merge hook or trls sync.","priority":"medium"}]
["create","E2-004",1773604016,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"PR-based done-to-merged workflow","type":"story","definition_of_done":"Issues transition to done when work complete, to merged only after PR merged. trls status shows issues awaiting merge separately. Supports GitHub PRs and plain git merges.","priority":"medium"}]
