["create","E2-001-T1",1773604198,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"Abstract issues directory path resolution by config mode","parent":"E2-001","type":"task","definition_of_done":"A function resolves the issues dir path: .issues/ for single-branch, worktree path for dual-branch. All commands use this instead of hardcoded paths.","priority":"high"}]
["create","E2-001-T2",1773604198,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"Git worktree management for issues branch","parent":"E2-001","type":"task","definition_of_done":"Functions to create/ensure orphan issues branch and git worktree pointing to it. Worktree is created on init when mode=dual-branch.","priority":"high"}]
["create","E2-001-T3",1773604198,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"Route op reads/writes through abstracted path","parent":"E2-001","type":"task","definition_of_done":"All commands (create, claim, transition, note, heartbeat) resolve ops path via the abstraction from T1. Existing single-branch behavior unchanged.","priority":"high"}]
["create","E2-001-T4",1773604198,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"Materialize pipeline accepts dynamic issues dir","parent":"E2-001","type":"task","definition_of_done":"Materialize() and MaterializeAndReturn() accept an issuesDir parameter. Pipeline reads ops from the correct location based on mode.","priority":"high"}]
["create","E2-001-T5",1773604198,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"Init command supports dual-branch mode flag","parent":"E2-001","type":"task","definition_of_done":"trls init --mode dual-branch creates orphan issues branch, sets up worktree, writes config with Mode=dual-branch.","priority":"medium"}]
["create","E2-001-T6",1773604198,"936c1188-4116-403f-a5ca-5ed7d9c6bf2b",{"title":"SingleBranchMode flag derived from config","parent":"E2-001","type":"task","definition_of_done":"Materialize engine SingleBranchMode is set based on config.Mode instead of hardcoded true. In dual-branch mode, done does not auto-promote to merged.","priority":"medium"}]
