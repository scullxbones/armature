["decision","E5-S0-T2",1774232800,"c69e037b-ef1d-4875-a05f-f5f0bd436682",{"topic":"dag-transition op reuse","choice":"reuse existing OpDAGTransition op type with IssueID payload field to distinguish subtree-promotion from per-issue DAG-confirmation","rationale":"Adding IssueID to Payload is backward-compatible: existing ops with Confirmed=true and no IssueID keep working unchanged; new ops with IssueID trigger subtree confidence promotion"}]
